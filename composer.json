{
    "name": "codraw/open-api",
    "description": "Open Api PHP manipulation library. Only support v 2.0",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "ext-json": "*",
        "codraw/core": "^0.39",
        "jms/serializer": "^3.11",
        "phpdocumentor/reflection-docblock": "^5.2",
        "symfony/config": "^6.4.0",
        "symfony/console": "^6.4.0",
        "symfony/dependency-injection": "^6.4.0",
        "symfony/event-dispatcher": "^6.4.0",
        "symfony/filesystem": "^6.4.0",
        "symfony/http-foundation": "^6.4.0",
        "symfony/http-kernel": "^6.4.0",
        "symfony/property-access": "^6.4.0",
        "symfony/routing": "^6.4.0",
        "symfony/validator": "^6.4.0"
    },
    "require-dev": {
        "ext-zip": "*",
        "codraw/dependency-injection": "^0.39",
        "codraw/tester": "^0.39",
        "doctrine/common": "^3.1",
        "doctrine/doctrine-bundle": "^2.5",
        "doctrine/orm": "^3.6",
        "phpunit/phpunit": "^11.3 || ^12.0"
    },
    "conflict": {
        "codraw/swagger": "*"
    },
    "suggest": {
        "ext-zip": "To run the draw:open-api:install-sandbox command",
        "codraw/framework-extra-bundle": "To integrate in Symfony",
        "doctrine/doctrine-bundle": "To enable Doctrine object construction, object reference handling and inheritance extraction"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\OpenApi\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        }
    },
    "replace": {
        "draw/open-api": "self.version"
    }
}
